<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> – Kishore Orthopedic Centre</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <section class="page-hero page-hero--image" style="background-image: url('/images/kishore-russia.png');">
      <div class="page-hero__overlay"></div>
      <div class="container page-hero__content" style="text-align:center;">
        <span class="section-tag section-tag--light">Meet the Doctor</span>
        <h1>Our Specialist</h1>
        <p>Fellowship-trained orthopedic surgeon with international expertise, dedicated to your recovery and well-being.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="doctor-profile">
          <div class="doctor-profile__photo">
            <img src="/images/doctor-kishore.png" alt="Dr. M. Kishore Kumar" class="doctor-profile__img" />
          </div>
          <div class="doctor-profile__info">
            <h2 class="doctor-profile__name">Dr. M. Kishore Kumar</h2>
            <p class="doctor-profile__quals">MS (Ortho) &nbsp;·&nbsp; DNB (Ortho) &nbsp;·&nbsp; MCH (Ortho) &nbsp;·&nbsp; FISS (Spine)</p>
            <p class="doctor-profile__title">Orthopedic &amp; Spine Surgeon</p>

            <div class="doctor-profile__section">
              <h4>International Fellowships</h4>
              <ul class="fellowship-list">
                <li>
                  <span class="fellowship-dot"></span>
                  <div>
                    <strong>Joint Replacement</strong>
                    <span>Advanced knee, hip &amp; shoulder replacement techniques</span>
                  </div>
                </li>
                <li>
                  <span class="fellowship-dot"></span>
                  <div>
                    <strong>Arthroscopy &amp; Sports Medicine</strong>
                    <span>Minimally invasive joint procedures for athletes and active individuals</span>
                  </div>
                </li>
                <li>
                  <span class="fellowship-dot"></span>
                  <div>
                    <strong>Spine Surgery</strong>
                    <span>Fellowship trained in Switzerland — complex spinal deformity and disc care</span>
                  </div>
                </li>
                <li>
                  <span class="fellowship-dot"></span>
                  <div>
                    <strong>Ilizarov &amp; Limb Reconstruction Surgery</strong>
                    <span>Trained in Kurgan, Russia — limb lengthening, deformity correction &amp; bone reconstruction</span>
                  </div>
                </li>
              </ul>
            </div>

            <div class="doctor-profile__section">
              <h4>Previous Experience</h4>
              <ul class="experience-list">
                <li class="experience-item">
                  <div class="experience-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  </div>
                  <div class="experience-content">
                    <strong>Designated Professor &amp; Head of Department</strong>
                    <span>Department of Orthopaedics</span>
                    <span class="experience-org">RIMS – Rajiv Institute of Medical Sciences, Ongole</span>
                  </div>
                </li>
                <li class="experience-item">
                  <div class="experience-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  </div>
                  <div class="experience-content">
                    <strong>Civil Surgeon</strong>
                    <span>Department of Orthopaedics</span>
                    <span class="experience-org">Government General Hospital, Ongole</span>
                  </div>
                </li>
              </ul>
            </div>

            <div class="doctor-profile__section">
              <h4>Areas of Expertise</h4>
              <div class="doctor-tags">
                <span class="tag">Joint Replacement</span>
                <span class="tag">Spine Surgery</span>
                <span class="tag">Arthroscopy</span>
                <span class="tag">Sports Medicine</span>
                <span class="tag tag--featured">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  Limb Reconstruction
                </span>
                <span class="tag tag--featured">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  Limb Lengthening
                </span>
                <span class="tag">Ilizarov Technique</span>
                <span class="tag">Fracture Care</span>
                <span class="tag">Trauma Surgery</span>
              </div>
            </div>

            <div class="doctor-profile__actions">
              <a href="/contact" class="btn btn-primary">Contact Clinic</a>
              <a href="https://wa.me/917093571238" target="_blank" rel="noopener" class="btn btn-whatsapp">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp Inquiry
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section-alt">
      <div class="container">
        <div class="cta-box">
          <div class="cta-content">
            <h2>Ready to Consult Dr. Kishore Kumar?</h2>
            <p>Get expert orthopedic care from a fellowship-trained specialist right here in Vijayawada.</p>
            <div class="cta-actions">
              <a href="/contact" class="btn btn-white btn-lg">Contact Clinic</a>
              <a href="https://wa.me/917093571238" target="_blank" rel="noopener" class="btn btn-outline-white btn-lg">WhatsApp Inquiry</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>

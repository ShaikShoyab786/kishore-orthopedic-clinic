<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> – Kishore Orthopedic Centre</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <section class="page-hero page-hero--image feedback-hero" style="background-image: url('/images/feedback-hero.jpg');">
      <div class="page-hero__overlay feedback-hero__overlay"></div>
      <div class="container page-hero__content" style="text-align:center;">
        <span class="section-tag section-tag--light">Patient Voice</span>
        <h1>Share Your Experience</h1>
        <p>Your feedback helps us improve and helps other patients make informed decisions about their care.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="feedback-layout">

          <div class="feedback-form-wrap">
            <% if (success) { %>
            <div class="feedback-success">
              <div class="feedback-success__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="32" height="32"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h2>Thank you for sharing your feedback.</h2>
              <p>Your review has been submitted and is awaiting approval. We appreciate you taking the time to share your experience at Kishore Orthopedic Centre.</p>
              <a href="/" class="btn btn-primary" style="margin-top:1.5rem;">Back to Home</a>
            </div>
            <% } else { %>

            <% if (error) { %>
            <div class="feedback-error">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <%= error %>
            </div>
            <% } %>

            <div class="feedback-form-card">
              <h2 class="feedback-form-card__title">Patient Feedback Form</h2>
              <p class="feedback-form-card__sub">All reviews are moderated before being displayed on our website.</p>

              <form method="POST" action="/feedback" class="feedback-form" novalidate>

                <div class="form-group">
                  <label for="patient_name">Your Name <span class="req">*</span></label>
                  <input type="text" id="patient_name" name="patient_name" placeholder="e.g. Ravi Kumar" maxlength="120" required autocomplete="name" />
                </div>

                <div class="form-group">
                  <label for="treatment">Treatment Taken <span class="req">*</span></label>
                  <input type="text" id="treatment" name="treatment" placeholder="e.g. Knee Replacement, Spine Surgery" maxlength="120" required />
                </div>

                <div class="form-group">
                  <label>Your Rating <span class="req">*</span></label>
                  <div class="star-rating-input" role="radiogroup" aria-label="Star rating">
                    <input type="radio" id="star5" name="rating" value="5" />
                    <label for="star5" title="5 stars – Excellent">★</label>
                    <input type="radio" id="star4" name="rating" value="4" />
                    <label for="star4" title="4 stars – Very Good">★</label>
                    <input type="radio" id="star3" name="rating" value="3" />
                    <label for="star3" title="3 stars – Good">★</label>
                    <input type="radio" id="star2" name="rating" value="2" />
                    <label for="star2" title="2 stars – Fair">★</label>
                    <input type="radio" id="star1" name="rating" value="1" />
                    <label for="star1" title="1 star – Poor">★</label>
                  </div>
                  <p class="star-hint">Click a star to rate your experience</p>
                </div>

                <div class="form-group">
                  <label for="message">Your Feedback <span class="req">*</span></label>
                  <textarea id="message" name="message" rows="5" placeholder="Please share your experience — how was the treatment, the care, and your overall visit?" maxlength="1000" required></textarea>
                  <span class="char-note">Maximum 1000 characters</span>
                </div>

                <button type="submit" class="btn btn-primary btn-full">Submit Feedback</button>
              </form>
            </div>
            <% } %>
          </div>

          <aside class="feedback-aside">
            <div class="feedback-aside-card">
              <div class="feedback-aside-card__img-wrap">
                <img src="/images/feedback-privacy.jpg" alt="Privacy and security" loading="lazy" />
              </div>
              <h3>Your Privacy Matters</h3>
              <p>Your feedback is reviewed by our team before being published. We never share personal details without consent.</p>
            </div>
            <div class="feedback-aside-card">
              <div class="feedback-aside-card__img-wrap">
                <img src="/images/feedback-helping.jpg" alt="Helping future patients" loading="lazy" />
              </div>
              <h3>Helping Future Patients</h3>
              <p>Genuine patient reviews help others in Vijayawada make confident decisions about their orthopedic care.</p>
            </div>
            <div class="feedback-aside-card">
              <div class="feedback-aside-card__img-wrap">
                <img src="/images/feedback-time.jpg" alt="Moderation timeline" loading="lazy" />
              </div>
              <h3>Moderation Takes 24–48 Hours</h3>
              <p>Approved feedback appears on our homepage. We respond to all reviews with a professional hospital reply.</p>
            </div>
          </aside>

        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>

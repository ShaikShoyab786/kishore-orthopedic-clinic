<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> – Kishore Orthopedic Clinic</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <section class="page-hero page-hero--image" style="background-image: url('/images/contact-hero.jpg');">
      <div class="page-hero__overlay"></div>
      <div class="container page-hero__content" style="text-align:center;">
        <span class="section-tag section-tag--light">Get In Touch</span>
        <h1>Contact Us</h1>
        <p>We're here to help. Reach out to schedule a consultation or ask us anything about our services.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="contact-layout">

          <!-- Contact Form -->
          <div class="contact-form-wrap">
            <h2>Send Us a Message</h2>
            <p class="form-subtitle">Fill in the form below and our team will get back to you within 24 hours.</p>
            <form class="contact-form" id="contactForm" novalidate>
              <div class="form-row">
                <div class="form-group">
                  <label for="firstName">First Name <span class="required">*</span></label>
                  <input type="text" id="firstName" name="firstName" placeholder="Ramesh" required />
                </div>
                <div class="form-group">
                  <label for="lastName">Last Name <span class="required">*</span></label>
                  <input type="text" id="lastName" name="lastName" placeholder="Kumar" required />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="phone">Phone Number <span class="required">*</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="97032 26789" required />
                </div>
                <div class="form-group">
                  <label for="email">Email Address</label>
                  <input type="email" id="email" name="email" placeholder="your@email.com" />
                </div>
              </div>
              <div class="form-group">
                <label for="department">Department / Speciality</label>
                <select id="department" name="department">
                  <option value="">Select a Department</option>
                  <option>Joint Replacement (Knee / Hip / Shoulder)</option>
                  <option>Spine Care</option>
                  <option>Arthroscopy &amp; Sports Medicine</option>
                  <option>Limb Reconstruction / Ilizarov</option>
                  <option>Physiotherapy &amp; Rehabilitation</option>
                  <option>Trauma &amp; Fracture Care</option>
                  <option>General Orthopedics</option>
                </select>
              </div>
              <div class="form-group">
                <label for="preferredDate">Preferred Date</label>
                <input type="date" id="preferredDate" name="preferredDate" />
              </div>
              <div class="form-group">
                <label for="message">Describe Your Condition <span class="required">*</span></label>
                <textarea id="message" name="message" rows="4" placeholder="Please briefly describe your symptoms or the reason for your visit..." required></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-lg btn-full">Send Message</button>
              <p class="form-note">By submitting this form you agree to be contacted by our team. We respect your privacy.</p>
            </form>
            <div class="form-success" id="formSuccess" style="display:none;">
              <div class="success-icon">✅</div>
              <h3>Message Received!</h3>
              <p>Thank you for reaching out. Our team will contact you within 24 hours.</p>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="contact-info-panel">
            <div class="info-card">
              <h3>Visit Us</h3>
              <div class="info-item">
                <span class="info-icon">📍</span>
                <div>
                  <strong>Address</strong>
                  <p>Sri Devi Apartments, Yalamalakuduru Lakulu Road,<br>Opp. Chaitanya Techno School,<br>Old Checkpost, Vijayawada – 520007</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">📞</span>
                <div>
                  <strong>Phone</strong>
                  <p><a href="tel:08662550000">0866-2550000</a> (Landline)</p>
                  <p><a href="tel:+919703226789">97032 26789</a> (Mobile)</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">✉️</span>
                <div>
                  <strong>Email</strong>
                  <p><a href="mailto:kishoreorthopediccenter@gmail.com">kishoreorthopediccenter@gmail.com</a></p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">💬</span>
                <div>
                  <strong>WhatsApp</strong>
                  <p><a href="https://wa.me/919703226789" target="_blank" rel="noopener">Chat on WhatsApp</a></p>
                </div>
              </div>
            </div>

            <div class="info-card">
              <h3>Clinic Timings</h3>
              <table class="timings-table">
                <tr>
                  <td>Monday – Saturday</td>
                  <td><strong>9:00 AM – 2:00 PM</strong></td>
                </tr>
                <tr>
                  <td>Monday – Saturday</td>
                  <td><strong>6:00 PM – 9:00 PM</strong></td>
                </tr>
                <tr>
                  <td>Sunday</td>
                  <td><strong>9:00 AM – 2:00 PM</strong></td>
                </tr>
              </table>
            </div>

            <div class="info-card info-card--map">
              <h3>How to Find Us</h3>
              <div class="map-placeholder">
                <div class="map-icon">🗺️</div>
                <p>Old Checkpost, Vijayawada<br>Andhra Pradesh – 520007</p>
                <a href="https://maps.google.com/?q=Sri+Devi+Apartments+Yalamalakuduru+Old+Checkpost+Vijayawada" target="_blank" rel="noopener" class="btn btn-outline btn-sm">Open in Google Maps</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Emergency Banner -->
    <section class="emergency-banner">
      <div class="container">
        <div class="emergency-content">
          <span class="emergency-icon">🚨</span>
          <div>
            <strong>Orthopedic Emergency?</strong>
            <p>Our team is available 24 hours a day, 7 days a week for emergencies.</p>
          </div>
          <a href="tel:08662550000" class="btn btn-white">Call 0866-2550000</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>

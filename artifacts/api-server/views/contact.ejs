<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> – Kishore Orthopedic Centre</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <section class="page-hero">
      <div class="container">
        <span class="section-tag">Get In Touch</span>
        <h1>Contact Us</h1>
        <p>We're here to help. Book an appointment, ask a question or simply find out more about our services.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="contact-layout">

          <!-- Contact Form -->
          <div class="contact-form-wrap">
            <h2>Book an Appointment</h2>
            <p class="form-subtitle">Fill in the form below and our team will get back to you within 24 hours.</p>
            <form class="contact-form" id="contactForm" novalidate>
              <div class="form-row">
                <div class="form-group">
                  <label for="firstName">First Name <span class="required">*</span></label>
                  <input type="text" id="firstName" name="firstName" placeholder="John" required />
                </div>
                <div class="form-group">
                  <label for="lastName">Last Name <span class="required">*</span></label>
                  <input type="text" id="lastName" name="lastName" placeholder="Doe" required />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="phone">Phone Number <span class="required">*</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required />
                </div>
                <div class="form-group">
                  <label for="email">Email Address</label>
                  <input type="email" id="email" name="email" placeholder="john@example.com" />
                </div>
              </div>
              <div class="form-group">
                <label for="department">Department / Speciality</label>
                <select id="department" name="department">
                  <option value="">Select a Department</option>
                  <option>Joint Replacement (Knee / Hip / Shoulder)</option>
                  <option>Spine Care</option>
                  <option>Sports Medicine</option>
                  <option>Physiotherapy & Rehabilitation</option>
                  <option>Pediatric Orthopedics</option>
                  <option>Trauma & Fracture Care</option>
                  <option>General Orthopedics</option>
                </select>
              </div>
              <div class="form-group">
                <label for="preferredDate">Preferred Date</label>
                <input type="date" id="preferredDate" name="preferredDate" />
              </div>
              <div class="form-group">
                <label for="message">Describe Your Condition <span class="required">*</span></label>
                <textarea id="message" name="message" rows="4" placeholder="Please briefly describe your symptoms or the reason for your visit..." required></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-lg btn-full">Send Appointment Request</button>
              <p class="form-note">By submitting this form you agree to be contacted by our team. We respect your privacy.</p>
            </form>
            <div class="form-success" id="formSuccess" style="display:none;">
              <div class="success-icon">✅</div>
              <h3>Request Received!</h3>
              <p>Thank you for reaching out. Our care coordinators will contact you within 24 hours to confirm your appointment.</p>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="contact-info-panel">
            <div class="info-card">
              <h3>Visit Us</h3>
              <div class="info-item">
                <span class="info-icon">📍</span>
                <div>
                  <strong>Address</strong>
                  <p>123, Main Road, Sector 5<br>Hyderabad, Telangana – 500001</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">📞</span>
                <div>
                  <strong>Phone</strong>
                  <p><a href="tel:+919876543210">+91 98765 43210</a></p>
                  <p><a href="tel:+914023456789">+91 40 2345 6789</a> (Clinic)</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">✉️</span>
                <div>
                  <strong>Email</strong>
                  <p><a href="mailto:info@kishoreortho.com">info@kishoreortho.com</a></p>
                  <p><a href="mailto:appointments@kishoreortho.com">appointments@kishoreortho.com</a></p>
                </div>
              </div>
            </div>

            <div class="info-card">
              <h3>Clinic Timings</h3>
              <table class="timings-table">
                <tr>
                  <td>Monday – Friday</td>
                  <td><strong>8:00 AM – 8:00 PM</strong></td>
                </tr>
                <tr>
                  <td>Saturday</td>
                  <td><strong>9:00 AM – 6:00 PM</strong></td>
                </tr>
                <tr>
                  <td>Sunday</td>
                  <td><strong>10:00 AM – 2:00 PM</strong></td>
                </tr>
                <tr class="emergency-row">
                  <td>Emergency</td>
                  <td><strong>24 Hours / 7 Days</strong></td>
                </tr>
              </table>
            </div>

            <div class="info-card info-card--map">
              <h3>How to Find Us</h3>
              <div class="map-placeholder">
                <div class="map-icon">🗺️</div>
                <p>Sector 5, Main Road<br>Hyderabad, Telangana</p>
                <a href="https://maps.google.com" target="_blank" rel="noopener" class="btn btn-outline btn-sm">Open in Google Maps</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Emergency Banner -->
    <section class="emergency-banner">
      <div class="container">
        <div class="emergency-content">
          <span class="emergency-icon">🚨</span>
          <div>
            <strong>Orthopedic Emergency?</strong>
            <p>Our trauma team is available 24 hours a day, 7 days a week.</p>
          </div>
          <a href="tel:+919876543210" class="btn btn-white">Call Emergency Now</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
